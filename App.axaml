<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:DropAndForget.UI;assembly=DropAndForget"
             x:Class="DropAndForget.App"
             Name="DropAndForget"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <ui:AppTheme />
        <StyleInclude Source="avares://DropAndForget/UI/DataGrid/Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    </Application.Styles>
</Application>
